# BYOK — kendi anahtarların. Bu dosya şablon; gerçek anahtarları .env'e koy (gitignore'lu).
# yargı modeli pinli Gemini; mekanikte Groq/OpenRouter failover.
GEMINI_API_KEY=
GEMINI_PAID_API_KEY=      # private mod (no-train + DPA)
GROQ_API_KEY=
OPENROUTER_API_KEY=

# --- Model seçimleri ---
# Yeni model çıkınca kod değişmez, buradaki satır değişir.
# Çözüm sırası: uygulama içi seçim → bu dosya → st.secrets → koddaki default.
# Uygulama içi seçim YALNIZ yargı modelini ve YALNIZ public modu etkiler;
# aşağıdakiler deploy sahibinin kontrolündedir. Boş bırakılan = koddaki default.
GEMINI_JUDGE_MODEL=gemini-3.5-flash
GEMINI_JUDGE_PRIVATE_MODEL=gemini-3.1-pro     # private mod; UI'dan değiştirilemez
GEMINI_MECHANICAL_MODEL=gemini-flash-lite
GROQ_MECHANICAL_MODEL=llama-3.3-70b-versatile # hem public hem private mekanik zincir
OPENROUTER_MECHANICAL_MODEL=deepseek/deepseek-r1:free
